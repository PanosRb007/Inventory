","suppressedMessages":"92","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"93","messages":"94","suppressedMessages":"95","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"96","messages":"97","suppressedMessages":"98","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"99","messages":"100","suppressedMessages":"101","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"102","messages":"103","suppressedMessages":"104","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"105","messages":"106","suppressedMessages":"107","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\index.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\App.js",["108"],[],"import React, { useState } from 'react';\r\nimport { BrowserRouter, Routes, Route, Link, useNavigate } from 'react-router-dom';\r\nimport Purchases from './pages/Purchases.js';\r\nimport Vendors from './pages/Vendors.js';\r\nimport Outflow from './pages/Outflow.js';\r\nimport MaterialList from './pages/MaterialList.js';\r\nimport Projects from './pages/Projects.js';\r\nimport ProjectOutflows from './pages/ProjectOutflows.js';\r\nimport Stock from './pages/Stock.js';\r\nimport Login from './pages/Login.js'; // Import the Login component\r\n\r\n\r\nimport './App.css'; // Import custom CSS for App component\r\n\r\nconst API_BASE_URL = 'https://api.robbie.gr';\r\n\r\nfunction App() {\r\n  const [isAuthenticated, setIsAuthenticated] = useState(false);\r\n\r\n  const handleLogin = (token) => {\r\n    localStorage.setItem('authToken', token); \r\n    console.log('local', localStorage);\r\n    setIsAuthenticated(true);\r\n  };\r\n\r\n  if (!isAuthenticated) {\r\n    return <Login onLogin={handleLogin} apiBaseUrl={API_BASE_URL} />;\r\n  }\r\n\r\n  return (\r\n    <div\r\n      className={'App'}>\r\n      <BrowserRouter>\r\n        <nav className=\"sidebar\">\r\n          <ul className=\"navbar-nav\">\r\n            <li className=\"nav-item\">\r\n              <Link to=\"/Purchases\" className=\"nav-link\">\r\n                <span>Inflow</span>\r\n              </Link>\r\n            </li>\r\n            <li className=\"nav-item\">\r\n              <Link to=\"/Outflow\" className=\"nav-link\">\r\n                <span>Outflow</span>\r\n              </Link>\r\n            </li>\r\n            <li className=\"nav-item\">\r\n              <Link to=\"/MaterialList\" className=\"nav-link\">\r\n                <span>Material List</span>\r\n              </Link>\r\n            </li>\r\n            <li className=\"nav-item\">\r\n              <Link to=\"/Vendors\" className=\"nav-link\">\r\n                <span>Vendor List</span>\r\n              </Link>\r\n            </li>\r\n            <li className=\"nav-item\">\r\n              <Link to=\"/Projects\" className=\"nav-link\">\r\n                <span>Project List</span>\r\n              </Link>\r\n            </li>\r\n            <li className=\"nav-item\">\r\n              <Link to=\"/Stock\" className=\"nav-link\">\r\n                <span>Stock</span>\r\n              </Link>\r\n            </li>\r\n          </ul>\r\n        </nav>\r\n        <main className=\"content\">\r\n          <header className=\"header\">\r\n            <h1 className=\"header-title\">ROBBIE</h1>\r\n          </header>\r\n          <Routes>\r\n          <Route path=\"/Purchases\" element={<Purchases apiBaseUrl={API_BASE_URL}/>} />\r\n            <Route path=\"/Outflow\" element={<Outflow apiBaseUrl={API_BASE_URL} />} />\r\n            <Route path=\"/Vendors\" element={<Vendors apiBaseUrl={API_BASE_URL}/>} />\r\n            <Route path=\"/MaterialList\" element={<MaterialList apiBaseUrl={API_BASE_URL}/>} />\r\n            <Route path=\"/Projects\" element={<Projects apiBaseUrl={API_BASE_URL}/>} />\r\n            <Route path=\"/ProjectOutflows\" element={<ProjectOutflows apiBaseUrl={API_BASE_URL}/>} />\r\n            <Route path=\"/Stock\" element={<Stock apiBaseUrl={API_BASE_URL}/>} />\r\n\r\n            {/* Add other routes for different pages */}\r\n          </Routes>\r\n        </main>\r\n      </BrowserRouter>\r\n    </div>\r\n  );\r\n}\r\n\r\nfunction ProtectedRoute({ children, isAuthenticated }) {\r\n  const navigate = useNavigate();\r\n\r\n  if (!isAuthenticated) {\r\n    navigate('/');\r\n    return null;\r\n  }\r\n\r\n  return children;\r\n}\r\n\r\nexport default App;\r\n","C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\reportWebVitals.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Purchases.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Outflow.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Vendors.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\MaterialList.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Projects.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\ProjectOutflows.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Stock.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\AddPurchase.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditPurchase.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\AddVendor.js",[],[],"C:\\Users\\SweetHome\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditOutflow.js",[],[],"C:\\Us