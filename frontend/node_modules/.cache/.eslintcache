nt":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"150","messages":"151","suppressedMessages":"152","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\index.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\App.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\reportWebVitals.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Purchases.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\MaterialList.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Vendors.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Outflow.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Stock.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Order_List.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\ProjectOutflows.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Projects.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\Login.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\MaterialCombiner.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\AddPurchase.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditMaterial.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\InstOut.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\PurchaseVerification.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\AddOutflow.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditOutflow.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditPurchase.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\AddMaterial.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditVendor.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditProject.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\CreateCombinedMaterial.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\AddProject.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditCombinedMaterial.js",["153"],[],"import React, { useState, useEffect } from 'react';\r\nimport Select from 'react-select';\r\nimport './CreateCombinedMaterial.css';\r\n\r\nconst EditCombinedMaterial = ({\r\n    materialId,\r\n    onClose,\r\n    fetchAPI,\r\n    apiBaseUrl,\r\n    onMaterialEdited,\r\n    materialchanges,\r\n}) => {\r\n    const [materialData, setMaterialData] = useState({ name: '', description: '', submaterials: [] });\r\n    const [allMaterials, setAllMaterials] = useState([]);\r\n    const [submaterials, setSubmaterials] = useState([]);\r\n    const [error, setError] = useState(null);\r\n    const [totalCost, setTotalCost] = useState(0);\r\n\r\n    useEffect(() => {\r\n        const fetchData = async () => {\r\n            try {\r\n                const materials = await fetchAPI(`${apiBaseUrl}/materiallist`);\r\n                setAllMaterials(materials);\r\n                const data = await fetchAPI(`${apiBaseUrl}/combinedMaterials/${materialId}`);\r\n                setMaterialData(data);\r\n                const submatdata = await fetchAPI(`${apiBaseUrl}/submaterials/${materialId}`);\r\n                setSubmaterials(submatdata);\r\n                calculateTotalCost(submatdata);\r\n            } catch (error) {\r\n                setError(error.message);\r\n            }\r\n        };\r\n        fetchData();\r\n    }, [materialId, fetchAPI, apiBaseUrl]);\r\n\r\n    const handleMaterialChange = (e) => {\r\n        const { name, value } = e.target;\r\n        setMaterialData(prevData => ({\r\n            ...prevData,\r\n            [name]: value,\r\n        }));\r\n    };\r\n\r\n    const handleSubmaterialChange = (index, field, value) => {\r\n        const updatedSubmaterials = submaterials.map((submat, i) =>\r\n            i === index ? { ...submat, [field]: value } : submat\r\n        );\r\n        setSubmaterials(updatedSubmaterials);\r\n        calculateTotalCost(updatedSubmaterials);\r\n    };\r\n\r\n    const addSubmaterial = () => {\r\n        setSubmaterials([...submaterials, { material_id: '', multiplier: 1 }]);\r\n    };\r\n\r\n    const removeSubmaterial = (index) => {\r\n        const filteredSubmaterials = submaterials.filter((_, i) => i !== index);\r\n        setSubmaterials(filteredSubmaterials);\r\n        calculateTotalCost(filteredSubmaterials);\r\n    };\r\n\r\n    const saveChanges = async () => {\r\n        if (!materialData.name || !materialData.description) {\r\n            setError(\"Please fill out all fields.\");\r\n            return;\r\n        }\r\n\r\n        try {\r\n            // Delete old submaterials\r\n            await fetchAPI(`${apiBaseUrl}/submaterials/${materialId}`, {\r\n                method: 'DELETE'\r\n            });\r\n\r\n            // Update combined material\r\n            await fetchAPI(`${apiBaseUrl}/combinedMaterials/${materialId}`, {\r\n                method: 'PUT',\r\n                headers: {\r\n                    'Content-Type': 'application/json',\r\n                },\r\n                body: JSON.stringify({ ...materialData }),\r\n            });\r\n\r\n            // Add new submaterials\r\n            await fetchAPI(`${apiBaseUrl}/submaterials`, {\r\n                method: 'POST',\r\n                headers: {\r\n                    'Content-Type': 'application/json',\r\n                },\r\n                body: JSON.stringify({ submaterials: submaterials.map(sub => ({ ...sub, combined_material_id: materialId })) }),\r\n            });\r\n\r\n            onMaterialEdited(); // Trigger refresh of material list\r\n            onClose(); // Close the popup\r\n        } catch (error) {\r\n            setError(error.message);\r\n        }\r\n    };\r\n\r\n    const calculateTotalCost = (submaterials) => {\r\n        const total = submaterials.reduce((acc, submaterial) => {\r\n            const sum = (materialchanges.find(p => p.material_id === submaterial.material_id)?.price || 0) * submaterial.multiplier;\r\n            return acc + sum;\r\n        }, 0);\r\n        setTotalCost(total.toFixed(2));\r\n    };\r\n\r\n    return (\r\n        <div className=\"material-input-form-container\">\r\n            <div className=\"material-input-form\">\r\n                <h3>Edit Combined Material</h3>\r\n                {error && <div className=\"error-message\">Error: {error}</div>}\r\n                <span className=\"close-popup\" onClick={onClose}>&times;</span>\r\n                <div className=\"form-row\">\r\n                    <div className=\"form-group\">\r\n                        <label htmlFor=\"name\">Name:</label>\r\n                        <input\r\n                            id=\"name\"\r\n                            name=\"name\"\r\n                            value={materialData.name}\r\n                            onChange={handleMaterialChange}\r\n                            className=\"form-control\"\r\n                        />\r\n                    </div>\r\n                    <div className=\"form-group\">\r\n                        <label htmlFor=\"description\">Description:</label>\r\n                        <textarea\r\n                            id=\"description\"\r\n                            name=\"description\"\r\n                            value={materialData.description}\r\n                            onChange={handleMaterialChange}\r\n                            className=\"form-control\"\r\n                        />\r\n                    </div>\r\n                </div>\r\n\r\n                {submaterials.map((submaterial, index) => (\r\n                    <div key={index} className=\"material-selection\">\r\n                        <div className=\"form-row\">\r\n                            <div className=\"form-group\">\r\n                                <label>Material</label>\r\n                                <Select\r\n                                    className=\"form-control\"\r\n                                    value={submaterial.material_id ? { value: submaterial.material_id, label: allMaterials.find(m => m.matid === submaterial.material_id)?.name } : null}\r\n                                    onChange={(selectedOption) => handleSubmaterialChange(index, 'material_id', selectedOption.value)}\r\n                                    options={allMaterials.map(material => ({ value: material.matid, label: material.name }))}\r\n                                    placeholder=\"Select Material\"\r\n                                    isSearchable={true}\r\n                                />\r\n                            </div>\r\n                            <div className=\"form-group\">\r\n                                <label>Multiplier</label>\r\n                                <input\r\n                                    type=\"number\"\r\n                                    value={submaterial.multiplier}\r\n                                    onChange={(e) => handleSubmaterialChange(index, 'multiplier', e.target.value)}\r\n                                    className=\"form-control\"\r\n                                />\r\n                            </div>\r\n                            <div className=\"form-group\">\r\n                                <label>Price</label>\r\n                                <input\r\n                                    type=\"number\"\r\n                                    value={(() => {\r\n                                        const filteredMaterialChanges = materialchanges.filter(p => p.material_id === submaterial.material_id);\r\n                                        const latestMaterialChange = filteredMaterialChanges.reduce((prev, current) => {\r\n                                            return prev.change_id > current.change_id ? prev : current;\r\n                                        }, {});\r\n                                        return latestMaterialChange.price || '';\r\n                                    })()}\r\n                                    readOnly\r\n                                    className=\"form-control\"\r\n                                />\r\n                            </div>\r\n\r\n                            <div className=\"form-group\">\r\n                                <label>Sum</label>\r\n                                <input\r\n                                    type=\"number\"\r\n                                    value={((materialchanges.find(p => p.material_id === submaterial.material_id)?.price || 0) * submaterial.multiplier).toFixed(2)}\r\n                                    readOnly\r\n                                    className=\"form-control\"\r\n                                />\r\n                            </div>\r\n\r\n                            <div className=\"form-group\">\r\n                                <label>Comments</label>\r\n                                <input\r\n                                    type=\"text\"\r\n                                    value={submaterial.comments}\r\n                                    onChange={(e) => handleSubmaterialChange(index, 'comments', e.target.value)}\r\n                                    className=\"form-control\"\r\n                                />\r\n                            </div>\r\n                            <div className=\"price-remove-container\">\r\n                                {submaterials.length > 1 && (\r\n                                    <button\r\n                                        className=\"remove-btn\"\r\n                                        onClick={() => removeSubmaterial(index)}\r\n                                    >\r\n                                        Remove\r\n                                    </button>\r\n                                )}\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                ))}\r\n\r\n                <div>\r\n                    <div className=\"total-cost-container\">\r\n                        <span className=\"total-cost-label\">Total Cost:</span>\r\n                        <span className=\"total-cost-value\">{totalCost}</span>\r\n                    </div>\r\n                    <button\r\n                        className=\"btn btn-primary add-btn\" onClick={addSubmaterial}>Add Submaterial</button>\r\n                    <button className=\"btn btn-success save-btn\" onClick={saveChanges}>Save Changes</button>\r\n                    <button className=\"remove-btn\" onClick={onClose}>Cancel</button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default EditCombinedMaterial;\r\n","C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\AddVendor.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\OutMatQuery.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\VendPurc.js",[],[],"C:\\Users\\PanagiotisRobescos\\OneDrive - ROBBIE\\Apps\\Inventory\\frontend\\src\\pages\\EditOrder.js",[],[],{"ruleId":"154","severity":1,"message":"155","line":34,"column":8,"nodeType":"156","endLine":34,"endColumn":42,"suggestions":"157"},"react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'calculateTotalCost'. Either include it or remove the dependency array.","ArrayExpression",["158"],{"desc":"159","fix":"160"},"Update the dependencies array to be: [materialId, fetchAPI, apiBaseUrl, calculateTotalCost]",{"range":"161","text":"162"},[1268,1302],"[materialId, fetchAPI, apiBaseUrl, calculateTotalCost]"]